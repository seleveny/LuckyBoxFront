/* components/auth-modal/auth-modal.wxss */
.auth-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 999;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
}

.auth-backdrop {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  animation: fadeIn 0.3s ease-out;
}

.auth-content {
  background-color: white;
  border-top-left-radius: 30rpx;
  border-top-right-radius: 30rpx;
  padding: 40rpx 30rpx;
  z-index: 1000;
  min-height: 50vh;
  max-height: 60vh;
  animation: slideUp 0.3s ease-out;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  box-sizing: border-box;
  box-shadow: 0 -5rpx 20rpx rgba(0, 0, 0, 0.1);
}

@keyframes slideUp {
  from {
    transform: translateY(100%);
  }
  to {
    transform: translateY(0);
  }
}

@keyframes fadeIn {
  from {
    opacity: 0;
  }
  to {
    opacity: 1;
  }
}

.auth-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 40rpx;
}

.auth-title {
  font-size: 26rpx;
  font-weight: bold;
  color: #333;
}

.auth-close {
  font-size: 44rpx;
  color: #999;
  line-height: 50rpx;
  height: 50rpx;
  width: 50rpx;
  text-align: center;
  border-radius: 50%;
  transition: all 0.3s ease;
  display: flex;
  align-items: center;
  justify-content: center;
}

.auth-close:hover {
  background-color: #f5f5f5;
}

.auth-body {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 50rpx;
  flex: 1;
  justify-content: center;
}

.auth-logo-placeholder {
  width: 140rpx;
  height: 140rpx;
  margin-bottom: 30rpx;
  border-radius: 24rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 50rpx;
  color: white;
  box-shadow: 0 10rpx 30rpx rgba(102, 126, 234, 0.3);
  animation: pulse 2s infinite;
}

@keyframes pulse {
  0% {
    box-shadow: 0 10rpx 30rpx rgba(102, 126, 234, 0.3);
  }
  50% {
    box-shadow: 0 15rpx 40rpx rgba(102, 126, 234, 0.5);
  }
  100% {
    box-shadow: 0 10rpx 30rpx rgba(102, 126, 234, 0.3);
  }
}

.auth-logo-placeholder::after {
  content: '🔒';
}

.auth-desc {
  font-size: 18rpx;
  color: #333;
  margin-bottom: 15rpx;
  text-align: center;
  font-weight: 500;
  line-height: 28rpx;
}

.auth-info {
  font-size: 14rpx;
  color: #999;
  text-align: center;
  line-height: 22rpx;
  max-width: 80%;
}

.auth-footer {
  display: flex;
  flex-direction: column;
  gap: 15rpx;
}

.auth-cancel,
.auth-confirm,
.auth-phone {
  width: 100%;
  height: 100rpx;
  border-radius: 50rpx;
  font-size: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 600;
  transition: all 0.3s ease;
  line-height: 1.2;
}

.auth-cancel {
  background-color: #f0f0f0;
  color: #666;
  border: none;
}

.auth-cancel:hover {
  background-color: #e0e0e0;
}

.auth-confirm {
  background: linear-gradient(135deg, #07c160 0%, #05a650 100%);
  color: white;
  border: none;
  box-shadow: 0 5rpx 15rpx rgba(7, 193, 96, 0.3);
}

.auth-confirm:hover {
  box-shadow: 0 8rpx 20rpx rgba(7, 193, 96, 0.4);
  transform: translateY(-2rpx);
}

.auth-phone {
  background: linear-gradient(135deg, #1890ff 0%, #096dd9 100%);
  color: white;
  border: none;
  box-shadow: 0 5rpx 15rpx rgba(24, 144, 255, 0.3);
}

.auth-phone:hover {
  box-shadow: 0 8rpx 20rpx rgba(24, 144, 255, 0.4);
  transform: translateY(-2rpx);
}

.auth-cancel::after,
.auth-confirm::after,
.auth-phone::after {
  border: none;
}
