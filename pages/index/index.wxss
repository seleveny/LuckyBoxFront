/* index.wxss */
page {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 50%, #f093fb 100%);
  min-height: 100vh;
}

.container {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx;
  padding-bottom: 160rpx;
  min-height: 100vh;
  box-sizing: border-box;
  position: relative;
}

/* 背景装饰 */
.container::before {
  content: '';
  position: fixed;
  top: -50%;
  right: -50%;
  width: 200%;
  height: 200%;
  background: radial-gradient(circle, rgba(255,255,255,0.1) 0%, transparent 60%);
  pointer-events: none;
  z-index: 0;
}

.content {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  flex: 1;
  text-align: center;
  font-size: 36rpx;
  color: white;
  font-weight: 600;
  text-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.2);
  z-index: 1;
}

.sub-text {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-top: 20rpx;
  font-weight: 400;
}

/* 页面标题 */
.page-header {
  width: 100%;
  text-align: center;
  margin-bottom: 30rpx;
  z-index: 1;
}

.page-title {
  font-size: 48rpx;
  color: white;
  font-weight: 800;
  text-shadow: 0 4rpx 15rpx rgba(0, 0, 0, 0.2);
  letter-spacing: 4rpx;
}

.page-subtitle {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
  margin-top: 10rpx;
  font-weight: 400;
}

.lottery-section {
  width: 100%;
  display: flex;
  align-items: flex-start;
  justify-content: center;
  padding-top: 20rpx;
  z-index: 1;
}

/* 底部功能条 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 140rpx;
  background: rgba(255, 255, 255, 0.95);
  backdrop-filter: blur(20rpx);
  display: flex;
  justify-content: flex-end;
  align-items: center;
  padding: 0 40rpx;
  padding-bottom: 30rpx;
  box-shadow: 0 -8rpx 40rpx rgba(0, 0, 0, 0.15);
  z-index: 100;
  border-top-left-radius: 40rpx;
  border-top-right-radius: 40rpx;
}

.bar-item {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  box-shadow: 0 8rpx 30rpx rgba(102, 126, 234, 0.4);
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

.bar-item:active {
  transform: scale(0.92);
  box-shadow: 0 4rpx 15rpx rgba(102, 126, 234, 0.3);
}

/* 人形图标 */
.user-icon {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.icon-head {
  width: 24rpx;
  height: 24rpx;
  border-radius: 50%;
  background-color: white;
  margin-bottom: 6rpx;
}

.icon-body {
  width: 40rpx;
  height: 24rpx;
  border-top-left-radius: 20rpx;
  border-top-right-radius: 20rpx;
  background-color: white;
}

/* 装饰元素 */
.decoration-circle {
  position: fixed;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.1);
  pointer-events: none;
  z-index: 0;
}

.decoration-1 {
  width: 300rpx;
  height: 300rpx;
  top: 10%;
  left: -100rpx;
}

.decoration-2 {
  width: 200rpx;
  height: 200rpx;
  top: 30%;
  right: -50rpx;
}

.decoration-3 {
  width: 150rpx;
  height: 150rpx;
  bottom: 20%;
  left: 10%;
}
