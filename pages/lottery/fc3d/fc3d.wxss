/* pages/lottery/fc3d/fc3d.wxss */
page {
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E53 100%);
  min-height: 100vh;
}

.container {
  display: flex;
  flex-direction: column;
  padding: 20rpx;
  padding-bottom: 40rpx;
  min-height: 100vh;
  box-sizing: border-box;
}

.header {
  text-align: center;
  margin-bottom: 30rpx;
}

.title {
  font-size: 48rpx;
  font-weight: 800;
  color: white;
  text-shadow: 0 4rpx 15rpx rgba(0, 0, 0, 0.2);
}

.lottery-table {
  background: white;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 8rpx 30rpx rgba(0, 0, 0, 0.15);
}

.table-scroll {
  overflow-x: auto;
  max-width: 100%;
}

.table-content {
  width: 100%;
  min-width: max-content;
}

.table-header {
  display: flex;
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E53 100%);
  min-width: max-content;
}

.header-cell {
  padding: 0;
  text-align: center;
  font-size: 26rpx;
  color: white;
  font-weight: 700;
  border-right: 1rpx solid rgba(255, 255, 255, 0.2);
  box-sizing: border-box;
  height: 70rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.header-cell.period-col {
  flex: 0 0 150rpx;
  max-width: 150rpx;
  min-width: 150rpx;
}

.header-cell.winning-col {
  flex: 0 0 120rpx;
  max-width: 120rpx;
  min-width: 120rpx;
}

.header-cell.digit-col {
  flex: 0 0 300rpx;
  max-width: 300rpx;
  min-width: 300rpx;
}

.table-body {
  min-width: max-content;
}

.table-row {
  display: flex;
  border-bottom: 1rpx solid #f0f0f0;
  min-width: max-content;
  margin: 0;
  padding: 0;
  height: 70rpx;
}

.table-row:last-child {
  border-bottom: none;
}

.cell {
  padding: 0;
  text-align: center;
  font-size: 26rpx;
  color: #333;
  border-right: 1rpx solid #f0f0f0;
  box-sizing: border-box;
  height: 70rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

/* 数字格子容器特殊处理 */
.cell.digit-col {
  align-items: stretch;
  padding: 0;
}

.cell.period-col {
  flex: 0 0 150rpx;
  max-width: 150rpx;
  min-width: 150rpx;
}

.cell.winning-col {
  flex: 0 0 120rpx;
  max-width: 120rpx;
  min-width: 120rpx;
}

.cell.digit-col {
  flex: 0 0 300rpx;
  max-width: 300rpx;
  min-width: 300rpx;
  padding: 0;
  margin: 0;
  border: none;
  outline: none;
}

.period {
  color: #666;
  font-weight: 600;
}

.winning-number {
  font-size: 32rpx;
  font-weight: 800;
  color: #ff6b6b;
  letter-spacing: 4rpx;
}

.digit-grid {
  display: flex;
  width: 100%;
  height: 100%;
  align-items: stretch;
  justify-content: center;
  box-sizing: border-box;
  margin: 0;
  padding: 0;
}

.digit-cell {
  flex: 1;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 600;
  color: #333;
  background: #f8f9fa;
  border-right: 1rpx solid #e0e0e0;
  transition: all 0.2s ease;
  margin: 0;
  padding: 0;
  box-sizing: border-box;
  text-align: center;
  line-height: 1;
  border-radius: 0;
  min-height: 100%;
}

.digit-cell:last-child {
  border-right: none;
}

/* 百位、十位、个位的背景色区分 */
.hundreds-col .digit-cell {
  background: #e3f2fd;
  color: #666;
}

.tens-col .digit-cell {
  background: #e8f5e8;
  color: #666;
}

.ones-col .digit-cell {
  background: #fff3e0;
  color: #666;
}

.digit-cell.selected {
  font-weight: 800;
  transform: scale(1.1);
  box-shadow: 0 4rpx 12rpx rgba(255, 107, 107, 0.4);
  z-index: 1;
  border-radius: 6rpx;
  transition: all 0.2s ease;
  align-items: center;
  justify-content: center;
  display: flex;
  line-height: 50rpx;
  height: 50rpx;
  margin: auto 0;
}

/* 中奖数字的样式 */
.hundreds-col .digit-cell.selected {
  background: #2196f3;
  color: white;
}

.tens-col .digit-cell.selected {
  background: #4caf50;
  color: white;
}

.ones-col .digit-cell.selected {
  background: #ff9800;
  color: white;
}

.toolbar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 30rpx;
  padding: 20rpx;
  background: rgba(255, 255, 255, 0.95);
  border-radius: 20rpx;
  box-shadow: 0 8rpx 30rpx rgba(0, 0, 0, 0.15);
}

.toolbar-left,
.toolbar-right {
  display: flex;
  gap: 20rpx;
}

.toolbar-center {
  display: flex;
  justify-content: center;
}

.toolbar-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 15rpx 25rpx;
  border-radius: 16rpx;
  background: linear-gradient(135deg, #f5f7fa 0%, #e4e8ec 100%);
  transition: all 0.2s ease;
}

.toolbar-btn:active {
  transform: scale(0.95);
}

.scan-btn {
  background: linear-gradient(135deg, #ff6b6b 0%, #ff8e53 100%);
  padding: 20rpx 40rpx;
}

.toolbar-icon {
  font-size: 36rpx;
  margin-bottom: 6rpx;
}

.toolbar-text {
  font-size: 22rpx;
  color: #333;
  font-weight: 600;
}

.scan-btn .toolbar-text {
  color: white;
}

.float-btn {
  position: fixed;
  right: 30rpx;
  bottom: 180rpx;
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 30rpx rgba(102, 126, 234, 0.4);
  transition: all 0.3s ease;
  z-index: 100;
}

.float-btn.expanded {
  width: 140rpx;
  border-radius: 50rpx;
}

.float-btn-content {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.float-icon {
  font-size: 40rpx;
  margin-bottom: 4rpx;
}

.float-text {
  font-size: 20rpx;
  color: white;
  font-weight: 700;
}

.vr-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.95);
  z-index: 1000;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s ease;
}

.vr-modal.show {
  opacity: 1;
  visibility: visible;
}

.vr-content {
  width: 100%;
  height: 100%;
  position: relative;
}

.vr-header {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 30rpx;
  background: rgba(0, 0, 0, 0.5);
  z-index: 100;
}

.vr-title {
  font-size: 32rpx;
  color: white;
  font-weight: 700;
}

.vr-close {
  font-size: 40rpx;
  color: white;
  opacity: 0.8;
}

.vr-body {
  padding: 0;
  position: relative;
  background: radial-gradient(circle at center, #2a2a4a 0%, #1a1a2e 50%, #0f0f1e 100%);
  min-height: 100vh;
  overflow: hidden;
}

/* 视口窗口：手机移动时，这个窗口移动，看板保持不动 */
.vr-viewport {
  width: 100%;
  height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  will-change: transform;
}

/* 场景容器 - 看板固定在这里，完全不动 */
.vr-scene-fixed {
  width: 2000rpx;
  height: 1500rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}

/* 3D容器 - 看板绝对固定，没有任何移动 */
.vr-3d-container-fixed {
  position: absolute;
  width: 2000rpx;
  height: 1500rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%);
}

/* 看板 - 直接使用普通页面的表格样式 */
.vr-board {
  width: auto;
  height: auto;
  background: white;
  border-radius: 20rpx;
  box-shadow: 0 40rpx 100rpx rgba(0, 0, 0, 0.8);
  overflow: hidden;
  transform: scale(var(--vr-scale, 2.5));
  transition: transform 0.3s ease;
}

/* VR中的表格 - 复用普通页面的样式 */
.vr-lottery-table {
  box-shadow: none;
  border-radius: 0;
}

.vr-controls {
  position: fixed;
  bottom: 40rpx;
  right: 40rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  z-index: 10;
}

.control-btn {
  width: 90rpx;
  height: 90rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s ease;
  backdrop-filter: blur(10rpx);
  border: 2rpx solid rgba(255, 255, 255, 0.3);
}

.control-btn:active {
  transform: scale(0.9);
  background: rgba(255, 255, 255, 0.4);
}

.control-btn.zoom-btn {
  background: rgba(100, 149, 237, 0.6);
}

.control-btn.zoom-btn:active {
  background: rgba(100, 149, 237, 0.8);
}

.control-btn.close-btn {
  background: rgba(255, 107, 107, 0.6);
}

.control-btn.close-btn:active {
  background: rgba(255, 107, 107, 0.8);
}

.control-icon {
  font-size: 48rpx;
  color: white;
  font-weight: bold;
}

.vr-info {
  position: fixed;
  bottom: 40rpx;
  left: 40rpx;
  background: rgba(0, 0, 0, 0.6);
  padding: 20rpx 30rpx;
  border-radius: 40rpx;
}

.info-text {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
}
