/* pages/lottery/fc3d/fc3d.wxss */
page {
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E53 100%);
  min-height: 100vh;
}

.container {
  display: flex;
  flex-direction: column;
  padding: 20rpx;
  padding-bottom: 40rpx;
  min-height: 100vh;
  box-sizing: border-box;
}

.header {
  text-align: center;
  margin-bottom: 30rpx;
}

.title {
  font-size: 48rpx;
  font-weight: 800;
  color: white;
  text-shadow: 0 4rpx 15rpx rgba(0, 0, 0, 0.2);
}

.lottery-table {
  background: white;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 8rpx 30rpx rgba(0, 0, 0, 0.15);
}

.table-scroll {
  overflow-x: auto;
  max-width: 100%;
}

.table-content {
  width: 100%;
  min-width: max-content;
}

.table-header {
  display: flex;
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E53 100%);
  min-width: max-content;
}

.header-cell {
  padding: 0;
  text-align: center;
  font-size: 26rpx;
  color: white;
  font-weight: 700;
  border-right: 1rpx solid rgba(255, 255, 255, 0.2);
  box-sizing: border-box;
  height: 70rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.header-cell.period-col {
  flex: 0 0 150rpx;
  max-width: 150rpx;
  min-width: 150rpx;
}

.header-cell.winning-col {
  flex: 0 0 120rpx;
  max-width: 120rpx;
  min-width: 120rpx;
}

.header-cell.digit-col {
  flex: 0 0 400rpx;
  min-width: 400rpx;
  max-width: 400rpx;
}

.header-cell:last-child {
  border-right: none;
}

.table-body {
  max-height: 70vh;
  overflow-y: auto;
}

.table-row {
  display: flex;
  border-bottom: 1rpx solid #f0f0f0;
  min-width: max-content;
  height: 70rpx;
}

.table-row:last-child {
  border-bottom: none;
}

.cell {
  padding: 0;
  text-align: center;
  font-size: 24rpx;
  color: #333;
  border-right: 1rpx solid #e0e0e0;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  height: 100%;
  min-height: 70rpx;
}

.cell.period-col {
  flex: 0 0 150rpx;
  max-width: 150rpx;
  min-width: 150rpx;
}

.cell.winning-col {
  flex: 0 0 120rpx;
  max-width: 120rpx;
  min-width: 120rpx;
}

.cell.digit-col {
  flex: 0 0 400rpx;
  min-width: 400rpx;
  max-width: 400rpx;
  padding: 0;
  height: 100%;
  min-height: 70rpx;
}

.cell:last-child {
  border-right: none;
}

.period {
  font-weight: 600;
  color: #666;
}

.winning-number {
  font-size: 32rpx;
  font-weight: 700;
  color: #FF6B6B;
  letter-spacing: 4rpx;
}

.digit-grid {
  display: flex;
  gap: 0;
  padding: 0;
  justify-content: flex-start;
  width: 100%;
  height: 100%;
  box-sizing: border-box;
}

.digit-cell {
  flex: 1;
  height: 100%;
  border-radius: 0;
  background-color: #f5f5f5;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
  color: #999;
  font-weight: 500;
  transition: all 0.2s ease;
  border-right: 1rpx solid #e0e0e0;
  box-sizing: border-box;
}

.digit-cell:nth-child(10) {
  border-right: none;
}

.digit-cell.selected {
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E53 100%);
  color: white;
  font-weight: 700;
  box-shadow: 0 2rpx 8rpx rgba(255, 107, 107, 0.3);
}

.toolbar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: white;
  border-top: 1rpx solid #e0e0e0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 10rpx 20rpx;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.1);
  z-index: 100;
}

.toolbar-left,
.toolbar-center,
.toolbar-right {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.toolbar-center {
  flex: 1;
  justify-content: center;
}

.toolbar-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 10rpx 20rpx;
  border-radius: 12rpx;
  transition: all 0.2s ease;
}

.toolbar-btn:active {
  background: #f5f5f5;
  transform: scale(0.95);
}

.scan-btn {
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E53 100%);
}

.scan-btn .toolbar-text {
  color: white;
}

.toolbar-icon {
  font-size: 32rpx;
  margin-bottom: 4rpx;
}

.toolbar-text {
  font-size: 20rpx;
  color: #666;
  font-weight: 500;
}

.float-btn {
  position: fixed;
  bottom: 120rpx;
  right: 20rpx;
  width: 100rpx;
  height: 100rpx;
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E53 100%);
  border-radius: 50rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 20rpx rgba(255, 107, 107, 0.4);
  z-index: 99;
  transition: all 0.3s ease;
  overflow: hidden;
}

.float-btn:active {
  transform: scale(0.95);
}

.float-btn.expanded {
  width: 200rpx;
  border-radius: 50rpx;
}

.float-btn-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.float-icon {
  font-size: 36rpx;
  margin-bottom: 2rpx;
}

.float-text {
  font-size: 24rpx;
  color: white;
  font-weight: 700;
}

.vr-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.7);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s ease;
}

.vr-modal.show {
  opacity: 1;
  visibility: visible;
}

.vr-content {
  width: 100%;
  height: 100vh;
  background: transparent;
  border-radius: 0;
  overflow: hidden;
  transform: scale(1);
  transition: all 0.3s ease;
}

.vr-modal.show .vr-content {
  transform: scale(1);
}

.vr-header {
  display: none;
}

.vr-title {
  font-size: 32rpx;
  font-weight: 700;
}

.vr-close {
  font-size: 40rpx;
  color: white;
  opacity: 0.8;
}

.vr-body {
  padding: 0;
  position: relative;
  background: radial-gradient(circle at center, #3a3a5a 0%, #2a2a4a 30%, #1a1a2e 60%, #0f0f1e 100%);
  min-height: 100vh;
  overflow: hidden;
}

.vr-scene {
  width: 100%;
  height: 100vh;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  perspective: 3000rpx;
  perspective-origin: center center;
}

.vr-3d-container {
  transition: transform 0.02s linear;
  position: absolute;
  width: 2000rpx;
  height: 1500rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  left: 50%;
  top: 50%;
  will-change: transform;
  transform-style: preserve-3d;
}

.vr-board {
  width: 100%;
  height: 100%;
  background: linear-gradient(135deg, #fff5e6 0%, #ffe6cc 100%);
  border: 20rpx solid #d4a574;
  border-radius: 50rpx;
  box-shadow: 0 60rpx 150rpx rgba(0, 0, 0, 0.95), inset 0 0 80rpx rgba(212, 165, 116, 0.3);
  overflow: hidden;
  transform-style: preserve-3d;
  transform: translateZ(-3000rpx) rotateX(5deg);
}

.board-header {
  background: linear-gradient(135deg, #d4a574 0%, #c49a6c 100%);
  padding: 80rpx;
  text-align: center;
  border-bottom: 8rpx solid #b8956a;
}

.board-title {
  display: block;
  font-size: 120rpx;
  font-weight: 800;
  color: #8b4513;
  margin-bottom: 20rpx;
  text-shadow: 4rpx 4rpx 8rpx rgba(255, 255, 255, 0.5);
}

.board-subtitle {
  display: block;
  font-size: 70rpx;
  color: #a0522d;
  font-weight: 600;
}

.board-content {
  padding: 60rpx;
}

.board-row {
  display: flex;
  align-items: center;
  padding: 30rpx 20rpx;
  border-bottom: 3rpx solid #e6d5c3;
  background: rgba(255, 255, 255, 0.5);
  margin-bottom: 20rpx;
  border-radius: 20rpx;
}

.board-row.header-row {
  background: linear-gradient(135deg, #d4a574 0%, #c49a6c 100%);
  border-bottom: 4rpx solid #b8956a;
  margin-bottom: 30rpx;
}

.board-row.header-row .board-cell {
  color: #8b4513;
  font-weight: 700;
  font-size: 60rpx;
}

.board-cell {
  flex: 1;
  text-align: center;
  font-size: 50rpx;
  color: #333;
  font-weight: 500;
}

.board-cell.period {
  color: #666;
  font-weight: 600;
}

.board-cell.winning {
  font-size: 70rpx;
  font-weight: 800;
  color: #ff6b6b;
  letter-spacing: 6rpx;
}

.board-cell.digit {
  font-size: 60rpx;
  font-weight: 700;
  color: #ff8e53;
  display: flex;
  align-items: center;
  justify-content: center;
}

.board-digit-grid {
  display: flex;
  width: 100%;
  height: 80rpx;
  overflow: hidden;
  border-radius: 10rpx;
}

.board-digit-cell {
  width: 10%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 1rpx solid #ddd;
  font-size: 40rpx;
  font-weight: 600;
  transition: all 0.3s ease;
}

.board-digit-cell.board-selected {
  background: linear-gradient(135deg, #ff6b6b 0%, #ff8e53 100%);
  color: white;
  font-weight: 800;
  transform: scale(1.05);
  box-shadow: 0 4rpx 12rpx rgba(255, 107, 107, 0.5);
}

.board-footer {
  background: linear-gradient(135deg, #d4a574 0%, #c49a6c 100%);
  padding: 60rpx;
  text-align: center;
  border-top: 8rpx solid #b8956a;
}

.footer-text {
  font-size: 50rpx;
  color: #8b4513;
  font-weight: 600;
}

.vr-controls {
  position: fixed;
  bottom: 40rpx;
  right: 40rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  z-index: 10;
}

.control-btn {
  width: 100rpx;
  height: 100rpx;
  background: rgba(255, 255, 255, 0.3);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  backdrop-filter: blur(20rpx);
  border: 3rpx solid rgba(255, 255, 255, 0.5);
  transition: all 0.2s ease;
}

.control-btn:active {
  background: rgba(255, 255, 255, 0.5);
  transform: scale(0.9);
}

.control-btn.close-btn {
  background: rgba(255, 107, 107, 0.5);
  border-color: rgba(255, 107, 107, 0.7);
}

.control-btn.close-btn:active {
  background: rgba(255, 107, 107, 0.7);
}

.control-icon {
  font-size: 48rpx;
  color: white;
}

.vr-info {
  position: fixed;
  bottom: 40rpx;
  left: 40rpx;
  background: rgba(0, 0, 0, 0.6);
  padding: 20rpx 30rpx;
  border-radius: 40rpx;
  backdrop-filter: blur(20rpx);
}

.info-text {
  font-size: 32rpx;
  color: rgba(255, 255, 255, 0.9);
  font-weight: 600;
}
